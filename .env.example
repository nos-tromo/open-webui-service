OPENAI_API_BASE_URL=http://vllm-router:4000/v1
OPENAI_API_KEY=sk-1234567890
INFERENCE_NET=inference-net
OPEN_WEBUI_HOST_PORT=8080
# Speech-to-text endpoint (OpenAI /v1 base). Unset => uses OPENAI_API_BASE_URL
# (production: vllm-router fronts the asr backend). Set to a dedicated ASR
# endpoint for dev — e.g. vllm-service's CPU asr-only stack:
# WHISPER_API_BASE=http://asr-only:8000/v1